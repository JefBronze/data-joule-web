# /opt/demo/.env  — copy this file to the VPS as /opt/demo/.env
# Consumed by create_demo_event.sh (sourced at the top).

# Same INGEST_API_KEY as the one in Vercel env vars and the Pi .env
INGEST_API_KEY=your_ingest_api_key_here

# Where the script POSTs event + grid-signal notifications
NOTIFY_URL=https://data-joule.com/api/demo/notify

# OpenADR VTN admin client secret (client_credentials grant).
# Previously fetched via `docker exec openadr3-vtn printenv VTN_ADMIN_SECRET`;
# now read from this .env so the script no longer depends on the container name.
ADMIN_SECRET=your_vtn_admin_secret_here

# Optional — EIA API key used by grid_signal.py for the US grid signal.
# Leave blank to run without it.
EIA_API_KEY=
